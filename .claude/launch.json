{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "frontend-dev",
      "runtimeExecutable": "wsl.exe",
      "runtimeArgs": [
        "-e",
        "bash",
        "-lc",
        "cd /home/user/repositories/type-quest/frontend && npm run dev"
      ],
      "port": 3000,
      "autoPort": false
    },
    {
      "name": "pachimon-frontend",
      "runtimeExecutable": "wsl.exe",
      "runtimeArgs": [
        "-e",
        "bash",
        "-lc",
        "cd /home/user/repositories/pachimon/frontend && npm run dev -- -p 3002"
      ],
      "port": 3002,
      "autoPort": false
    },
    {
      "name": "frontend-dev-alt",
      "runtimeExecutable": "wsl.exe",
      "runtimeArgs": [
        "-e",
        "bash",
        "-lc",
        "cd /home/user/repositories/type-quest/frontend && npm run dev -- -p 3003"
      ],
      "port": 3003,
      "autoPort": false
    }
  ]
}
